# Copy to .env and fill in your API keys.

# LLM API keys
GROQ_API_KEY=gsk_your_groq_api_key_here        # https://console.groq.com/
GEMINI_API_KEY=your_gemini_api_key_here        # https://aistudio.google.com/

# PostgreSQL
POSTGRES_USER=cloudguard
POSTGRES_PASSWORD=cloudguard_secret
POSTGRES_DB=cloudguard_db
DATABASE_URL=postgresql+asyncpg://cloudguard:cloudguard_secret@postgres:5432/cloudguard_db

# S3. For local dev this points at LocalStack with dummy credentials.
# In production, delete AWS_ENDPOINT_URL and leave the key pair empty so
# boto3 uses the instance IAM role, then set a globally unique bucket name.
AWS_ENDPOINT_URL=http://localstack:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET_NAME=cloudguard-artifacts

# App
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
# Lock this down to your domain in production, e.g. https://cloudguard.example.com
CORS_ORIGINS=*
